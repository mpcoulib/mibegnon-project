generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooler (6543) → app runtime
  directUrl = env("DIRECT_URL")   // direct (5432) → migrations only
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum EducationLevel {
  TROISIEME
  SECONDE
  PREMIERE
  TERMINALE
  BAC_PLUS_1
  BAC_PLUS_2
}

enum ApplicationStatus {
  INTERESSE
  EN_PREPARATION
  POSTULE
  EN_ATTENTE
  ACCEPTE
  REFUSE
}

enum DonationStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum DonationKind {
  ONE_TIME
  MONTHLY
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id              String          @id // matches Supabase Auth UUID
  email           String          @unique
  fullName        String
  phone           String?
  city            String?
  educationLevel  EducationLevel?
  fieldOfStudy    String?
  gpa             Float?
  targetCountries String[]
  targetFields    String[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  bookmarks    Bookmark[]
  applications Application[]

  @@map("users")
}

model Scholarship {
  id             String    @id @default(cuid())
  name           String
  provider       String
  country        String
  amount         Float?
  currency       String    @default("USD")
  isFullFunding  Boolean   @default(false)
  deadline       DateTime?
  academicLevels String[]  // e.g. ["BACHELOR", "MASTER"]
  fields         String[]  // e.g. ["Informatique", "Médecine"]
  description    String    @db.Text
  requirements   String?   @db.Text
  category       String?  @db.Text
  link             String
  isActive         Boolean   @default(true)
  ivoirianEligible Boolean   @default(true)
  isTranslated     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bookmarks    Bookmark[]
  applications Application[]

  @@index([isActive, isTranslated])
  @@index([isActive, deadline])
  @@index([category])
  @@index([country])
  @@map("scholarships")
}

model University {
  id              String   @id @default(cuid())
  name            String
  country         String
  city            String
  website         String
  ranking         Int?
  tuitionFee      Float?
  tuitionCurrency String   @default("USD")
  hasScholarships Boolean  @default(false)
  fields          String[]
  description     String?  @db.Text
  logoUrl         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookmarks    Bookmark[]
  applications Application[]

  @@index([isActive])
  @@map("universities")
}

model Bookmark {
  id            String       @id @default(cuid())
  userId        String
  scholarshipId String?
  universityId  String?
  createdAt     DateTime     @default(now())

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship Scholarship?  @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  university  University?   @relation(fields: [universityId], references: [id], onDelete: Cascade)

  @@unique([userId, scholarshipId])
  @@unique([userId, universityId])
  @@index([userId])
  @@index([scholarshipId])
  @@index([universityId])
  @@map("bookmarks")
}

model Application {
  id            String            @id @default(cuid())
  userId        String
  scholarshipId String?
  universityId  String?
  status        ApplicationStatus @default(INTERESSE)
  notes         String?           @db.Text
  deadline      DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship Scholarship? @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  university  University?  @relation(fields: [universityId], references: [id], onDelete: Cascade)
  documents   Document[]

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@index([scholarshipId])
  @@index([universityId])
  @@map("applications")
}

model SavedScholarship {
  id            String   @id @default(cuid())
  userId        String
  scholarshipId String
  createdAt     DateTime @default(now())

  @@unique([userId, scholarshipId])
  @@index([userId])
  @@map("saved_scholarships")
}

model Document {
  id            String      @id @default(cuid())
  applicationId String
  name          String
  isCompleted   Boolean     @default(false)
  dueDate       DateTime?
  createdAt     DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("documents")
}



model ScholarshipSubmission {
  id             String    @id @default(cuid())
  name           String
  provider       String
  country        String
  link           String
  academicLevels String[]
  isFullFunding  Boolean   @default(false)
  deadline       DateTime?
  description    String    @db.Text
  submitterEmail String?
  submitterNote  String?   @db.Text
  status         String    @default("pending")
  createdAt      DateTime  @default(now())

  @@map("scholarship_submissions")
}

model Donation {
  id                      String         @id @default(cuid())
  amountCents             Int
  currency                String         @default("eur")
  kind                    DonationKind
  status                  DonationStatus @default(PENDING)
  donorName               String?
  donorEmail              String?
  publicMessage           String?        @db.Text
  isAnonymous             Boolean        @default(false)
  displayName             String?
  stripeCheckoutSessionId String?        @unique
  stripeSubscriptionId    String?
  stripeCustomerId        String?
  stripePaymentIntentId   String?
  succeededAt             DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([status, succeededAt])
  @@index([createdAt])
  @@map("donations")
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  createdAt     DateTime @default(now())

  @@map("stripe_webhook_events")
}

model CronRun {
  id          String   @id @default(cuid())
  job         String
  deactivated Int      @default(0)
  purged      Int      @default(0)
  skipped     Int      @default(0)
  errors      String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([job, createdAt])
  @@map("cron_runs")
}
